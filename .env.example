# ─── NextAuth ────────────────────────────────────────────────────────────────
# NEXTAUTH_URL: your production URL (set automatically on Vercel, but keep for local dev)
NEXTAUTH_URL=https://your-app.vercel.app

# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate a strong secret
NEXTAUTH_SECRET=REPLACE_WITH_STRONG_SECRET_32_CHARS_MIN

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ─── Credentials (production) ─────────────────────────────────────────────────
# Paste the full content of data/credentials.json as a single-line JSON string.
# On Vercel: add this in Project Settings → Environment Variables.
#
# To generate the value, run in terminal:
#   node -e "const f=require('./data/credentials.json');console.log(JSON.stringify(f))"
#
# Example (DO NOT use these values in production — change all passwords/keys!):
CREDS_JSON={"manager":{"email":"admin@proji.com","passwordHash":"$2b$10$...","lobbyKey":"PROJI-2024-ALPHA","role":"manager","allowedDomains":["all"]},"employer":{"email":"employer@proji.com","passwordHash":"$2b$10$...","lobbyKey":"PROJI-EMP-2024","role":"employer","allowedDomains":["Маркетинг"]},"domains":[{"name":"Общий","key":"GEN-XXXX","password":"gen-password"}]}
